---
const data = [
  { name: "Ada", ns: 188 },
  { name: "Servo URL", ns: 664 },
  { name: "cURL", ns: 1471 },
]
const max = 2000
---

<section aria-labelledby="benchmarks-heading">
  <header>
    <h2 id="benchmarks-heading">Ada is fast</h2>
    <p>
      On a benchmark where we need to validate and normalize{" "}
      <a
        href="https://github.com/ada-url/url-various-datasets/tree/main/top100"
      >
        thousands of URLs found on popular websites
      </a>{" "} we find that ada can be several times faster than popular competitors.
    </p>
  </header>
  <figure>
    <figcaption class="sr-only">URL parsing speed comparison (lower is faster)</figcaption>
    <div class="bar-chart">
      {data.map(({ name, ns }) => (
        <div class="bar-row">
          <span class="bar-label">{name}</span>
          <div class="bar-track">
            <div class="bar" style={`--w: ${(ns / max * 100).toFixed(2)}%`}></div>
          </div>
          <span class="bar-value">{ns}<abbr title="nanoseconds per URL"> ns/URL</abbr></span>
        </div>
      ))}
    </div>
  </figure>
</section>

<style>
  section {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-right: auto;
    margin-left: auto;
    padding-inline: 2rem;
    padding-block: 2rem;
    background-color: rgb(248 250 252)
  }

  header {
    margin-inline: auto;
    display: flex;
    max-width: 58rem;
    align-items: center;
    text-align: center;
    flex-direction: column;
    row-gap: 16px;
  }

  p {
    max-width: 85%;
    line-height: 1.5;
    color: var(--sl-color-gray-3)
  }

  h2 {
    font-size: 3.75rem;
    line-height: 1;
  }

  a {
    font-weight: 700;
  }

  figure {
    margin: 0;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .bar-chart {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 800px;
    margin-inline: auto;
    width: 100%;
  }

  .bar-row {
    display: grid;
    grid-template-columns: 6.5rem 1fr 6.5rem;
    align-items: center;
    gap: 0.75rem;
  }

  .bar-label {
    text-align: right;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--sl-color-gray-3);
  }

  .bar-track {
    height: 2.5rem;
    border-radius: 0.5rem;
    background: var(--sl-color-gray-6);
    overflow: hidden;
  }

  .bar {
    height: 100%;
    width: var(--w);
    background: #8884d8;
    border-radius: 0.5rem;
    transition: background 0.15s;
  }

  .bar:hover {
    background: #7874c8;
  }

  .bar-value {
    font-size: 0.75rem;
    font-variant-numeric: tabular-nums;
    color: var(--sl-color-gray-3);
  }

  abbr {
    text-decoration: none;
  }

  :root[data-theme="dark"] {
    & p,
    & .bar-label,
    & .bar-value {
      color: var(--sl-color-gray-2);
    }

    & section {
      background-color: transparent;
    }
  }

  @media (max-width: 768px) {
    h2 {
      font-size: 1.875rem;
      line-height: 2.25rem;
    }

    .bar-row {
      grid-template-columns: 5.5rem 1fr 5rem;
    }
  }

  @media (min-width: 640px) {
    p {
      font-size: 1.125rem;
      line-height: 1.75rem;
    }
  }

  @media (min-width: 1400px) {
    section {
      max-width: 1400px;
    }
  }
</style>
